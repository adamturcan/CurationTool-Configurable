# Base path for the app. Defaults to /DataCurationTool/ for the GitHub Pages
# deployment; use "/" for Docker or standalone local hosting.
VITE_BASE_PATH=/

# NLP API endpoints
VITE_NER_API_URL=https://ner-api.dev.memorise.sdu.dk/recognize
VITE_SEGMENT_API_URL=https://textseg-api.dev.memorise.sdu.dk/segment
VITE_CLASSIFY_API_URL=https://semtag-api.dev.memorise.sdu.dk/classify
VITE_TRANSLATION_API_URL=https://mt-api.dev.memorise.sdu.dk/translate
VITE_TRANSLATION_LANGUAGES_URL=https://mt-api.dev.memorise.sdu.dk/supported_languages

# Thesaurus index URL (default: static file from public/)
# VITE_THESAURUS_URL=/thesaurus-index.json

# App branding (optional)
# VITE_APP_TITLE=Memorise UI
# VITE_APP_LOGO=/memorise.png
# VITE_APP_LOGO_FULL=/memorise-dct.png

# Set to enable remote storage mode (requires backend running)
# VITE_BACKEND_URL=http://localhost:8080
